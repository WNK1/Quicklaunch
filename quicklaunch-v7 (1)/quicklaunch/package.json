{
  "name": "quicklaunch",
  "version": "2.0.0",
  "description": "QuickLaunch — Start Menu App Panel for Windows 11",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.quicklaunch.app",
    "productName": "QuickLaunch",
    "win": { "target": "nsis", "icon": "assets/icon.ico" },
    "nsis": { "oneClick": true, "perMachine": false },
    "files": ["main.js","preload.js","src/**/*","assets/**/*"],
    "directories": { "output": "build" }
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  }
}
