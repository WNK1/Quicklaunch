# ─────────────────────────────────────────────────────────────────
# CSDROP — environment variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────

# Steam Web API key
# Get one at: https://steamcommunity.com/dev/apikey
# (Register your site domain; for local dev use "localhost")
STEAM_API_KEY=your_steam_api_key_here

# The URL where your server is running (NO trailing slash)
# For local dev: http://localhost:3000
# For production: https://yourdomain.com
SITE_URL=http://localhost:3000

# Secret used to sign session cookies — change this to any long random string
SESSION_SECRET=change-this-to-a-random-string-min-32-chars

# Port the server listens on (optional, default: 3000)
PORT=3000

# Set to "production" when deploying to get secure cookies
# NODE_ENV=production
